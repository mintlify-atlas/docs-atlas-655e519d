  "keyFeatures": [
    "AI-powered conversation with Claude via Vercel AI SDK",
    "Code execution in E2B sandboxes with persistent sessions per thread",
    "Web search integration via Exa API",
    "Scheduled tasks and reminders with cron expressions",
    "Image generation and Mermaid diagram rendering",
    "Thread summarization and conversation history",
    "Rate limiting and caching with Redis",
    "Observability with OpenTelemetry and Langfuse",
    "Multiple AI model providers (Hack Club, OpenRouter)",
    "Rich Slack integration with reactions, replies, and user info"
  ],
  "publicApiSurface": [
    "reply - Send messages to Slack channels/threads",
    "react - Add emoji reactions to messages",
    "searchWeb - Search the web using Exa",
    "sandbox - Execute code in E2B sandboxes",
    "getUserInfo - Fetch Slack user information",
    "scheduleTask - Create recurring tasks with cron",
    "scheduleReminder - Schedule one-time reminders",
    "cancelScheduledTask - Cancel scheduled tasks",
    "listScheduledTasks - View all scheduled tasks",
    "generateImage - Create images using AI",
    "mermaid - Render Mermaid diagrams",
    "summariseThread - Summarize conversation threads",
    "readConversationHistory - Access message history",
    "searchSlack - Search Slack messages",
    "leaveChannel - Leave Slack channels",
    "skip - Skip responding to a message"
  ]
}
